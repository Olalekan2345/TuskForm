# ── Email — Brevo SMTP (free 300/day, sign up at brevo.com) ──────────────────
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_KEY=xsmtpsib-...

# ── Walrus storage ────────────────────────────────────────────────────────────
WALRUS_NETWORK=mainnet
NEXT_PUBLIC_WALRUS_NETWORK=mainnet
NEXT_PUBLIC_WALRUS_EPOCHS=52
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_EPOCHS=52

# ── Server wallet (needs SUI for gas + WAL for storage) ──────────────────────
SERVER_WALLET_KEY=suiprivkey1...

# ── Internal API secret (protects /api/walrus/store and /api/walrus/upload) ──
# Generate with: openssl rand -hex 32
# Must be set in Railway AND here (as NEXT_PUBLIC_ so the browser sends it)
INTERNAL_API_SECRET=your_random_secret_here
NEXT_PUBLIC_INTERNAL_API_SECRET=your_random_secret_here

# ── Upstash Redis (persistent response index — free at upstash.com) ──────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Mysten Seal (wallet-gated field encryption) ───────────────────────────────
NEXT_PUBLIC_SEAL_PACKAGE_ID=0x3b179126a88104d254ffdea2157e173fe715b0d8acf7306c50b03076fa0fe14b
